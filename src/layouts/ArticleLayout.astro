---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  pillar: string;
  image?: string;
  currentSlug?: string;
}

const { title, description, date, updated, pillar, image, currentSlug } = Astro.props;

// Get related articles (same pillar, excluding current)
const allArticles = await getCollection('thinking', ({ data }) => data.published);
const relatedArticles = allArticles
  .filter(a => a.data.pillar === pillar && a.id !== currentSlug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const pillarLabels: Record<string, string> = {
  'merchant-mindset': 'Merchant Mindset',
  'brand-growth': 'Brand Growth',
  'ai-selling': 'AI & Selling',
  'habit-philosophy': 'Habit Philosophy',
  'founder-documentary': 'Founder Documentary',
};

const purplePillars = ['ai-selling', 'habit-philosophy'];
const isPurple = purplePillars.includes(pillar);

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": (updated || date).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Ashraf Hassan",
    "alternateName": "Ashmo",
    "url": "https://ashmo.io/story"
  },
  "publisher": {
    "@type": "Person",
    "name": "Ashraf Hassan",
    "url": "https://ashmo.io"
  },
  "mainEntityOfPage": canonicalURL.toString(),
  ...(image ? { "image": new URL(image, Astro.site).toString() } : {})
};
---

<BaseLayout title={title} description={description} image={image} type="article" publishedDate={date}>

  <!-- Article JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="max-w-[1200px] mx-auto px-6 md:px-12 pt-8 md:pt-16 pb-20 md:pb-28">
    <div class="max-w-[680px]">

      <!-- Meta -->
      <div class="flex items-center gap-6 mb-10">
        <span
          class="text-[0.667rem] font-medium uppercase tracking-[0.12em]"
          style={`color: ${isPurple ? 'var(--color-secondary)' : 'var(--color-accent)'}`}
        >
          {pillarLabels[pillar] || pillar}
        </span>
        <span class="w-px h-4 bg-border"></span>
        <span class="text-[0.778rem] text-text-tertiary">{formattedDate}</span>
      </div>

      <!-- Title -->
      <h1 class="font-heading text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-8 max-w-[640px]">
        {title}
      </h1>

      <!-- Lead -->
      <p class="text-xl md:text-[1.22rem] text-text-secondary leading-relaxed font-light mb-12 max-w-[600px]">
        {description}
      </p>

      <!-- Separator -->
      <div class="w-12 h-px mb-12" style={`background: ${isPurple ? 'var(--color-secondary)' : 'var(--color-accent)'}`}></div>

      <!-- Body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Author -->
      <div class="mt-20 pt-10 border-t border-border flex items-center gap-5">
        <div class="w-12 h-12 rounded-full bg-surface border border-border flex items-center justify-center text-xs text-text-tertiary">A</div>
        <div>
          <p class="text-[0.889rem] font-medium text-text">Ashmo</p>
          <p class="text-sm text-text-tertiary">Founder, brand builder, and merchant philosopher. <a href="/story" class="text-accent hover:text-accent-light">Read my story</a></p>
        </div>
      </div>

      <!-- Related Articles -->
      {relatedArticles.length > 0 && (
        <div class="mt-16 pt-10 border-t border-border">
          <h2 class="text-[0.889rem] font-body font-medium uppercase tracking-[0.08em] text-text-tertiary mb-8">Keep Reading</h2>
          <div class="flex flex-col gap-6">
            {relatedArticles.map(article => (
              <a href={`/thinking/${article.id}`} class="group block no-underline">
                <h3 class="font-heading text-lg font-semibold text-text group-hover:text-accent transition-colors mb-1">{article.data.title}</h3>
                <p class="text-sm text-text-tertiary font-light">{article.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </article>

</BaseLayout>
