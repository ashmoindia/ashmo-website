---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { personId, personSchema, socialProfiles, websiteId, websiteSchema } from '../data/entity';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const {
  title,
  description = "Notes on brand building, merchant thinking, and the discipline of showing up.",
  image = "/og-default.jpg",
  type = "website",
  publishedDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const brandName = "Ashraf Hassan";
const fullTitle = title === "Home"
  ? "Ashraf Hassan (Ashmo) — Founder, Brand Builder, Writer"
  : title.includes(brandName)
    ? title
    : `${title} — ${brandName}`;
const pageImageURL = new URL(image, Astro.site).toString();
const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalURL.toString()}#webpage`,
  "url": canonicalURL.toString(),
  "name": fullTitle,
  "description": description,
  "isPartOf": { "@id": websiteId },
  "about": { "@id": personId },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": pageImageURL,
  },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-TB2V4B96');</script>
  <!-- End Google Tag Manager -->

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="facebook-domain-verification" content="i188gkfpwpvp9w4w7qvu3f9m1omi63" />
  <link rel="icon" type="image/svg+xml" href="/favicon-emblem.svg" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={pageImageURL} />
  {type === 'article' && publishedDate && (
    <meta property="article:published_time" content={publishedDate.toISOString()} />
  )}
  {type === 'article' && <meta property="article:author" content="Ashraf Hassan" />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@iamashmo" />
  <meta name="twitter:creator" content="@iamashmo" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={pageImageURL} />

  {socialProfiles.map((profile) => <link rel="me" href={profile} />)}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

  <meta name="generator" content={Astro.generator} />

  <!-- JSON-LD: entity graph -->
  <script type="application/ld+json" set:html={JSON.stringify([
    personSchema,
    websiteSchema,
    webpageSchema,
  ])} />
</head>
<body class="bg-bg text-text font-body leading-relaxed">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TB2V4B96"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-bg focus:px-4 focus:py-2 focus:rounded focus:text-sm">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
