---
const year = new Date().getFullYear();
const primaryLinks = [
  { href: '/thinking/', label: 'Thinking' },
  { href: '/restaurant-finance/', label: 'Finance' },
  { href: '/work/', label: 'Work' },
  { href: '/story/', label: 'Story' },
  { href: '/contact/', label: 'Contact' },
];

const utilityLinks = [
  { href: '/privacy-policy/', label: 'Privacy' },
  { href: '/terms/', label: 'Terms' },
  {
    href: 'https://www.linkedin.com/in/iamashmo/',
    label: 'LinkedIn',
    external: true,
  },
];
---

<footer class="max-w-[1200px] mx-auto px-6 md:px-12 border-t border-border">
  <div class="py-10 md:py-12 flex flex-col gap-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 md:gap-10">
      <div class="max-w-[420px]">
        <a href="/ashraf-hassan/" class="inline-flex items-baseline gap-2 no-underline">
          <span class="text-sm text-text font-medium">Ashraf Hassan</span>
          <span class="text-sm text-accent italic">(Ashmo)</span>
        </a>
        <p class="mt-2 text-sm text-text-tertiary leading-relaxed">
          Founder, brand builder, writer, and operator.
        </p>
      </div>

      <nav aria-label="Footer" class="flex flex-wrap gap-x-5 gap-y-2 md:justify-end">
        {primaryLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs text-text-tertiary hover:text-text-secondary transition-colors no-underline"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="pt-4 border-t border-border-light flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-xs text-text-tertiary">&copy; {year} Ashmo</p>

      <div class="flex flex-wrap gap-x-4 gap-y-2">
        {utilityLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'me noopener' : undefined}
            class="text-xs text-text-tertiary hover:text-text-secondary transition-colors no-underline"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
