---
interface Props {
  number: string;
  title: string;
  description: string;
  purple?: boolean;
}

const { number, title, description, purple = false } = Astro.props;
---

<a
  href="/thinking"
  class:list={[
    "block bg-surface border border-border rounded-lg p-8 md:p-9 transition-all duration-200 no-underline",
    purple
      ? "hover:border-secondary"
      : "hover:border-accent",
    "hover:bg-surface-hover",
  ]}
>
  <p
    class="text-[0.667rem] tracking-[0.1em] uppercase mb-5"
    style={`color: ${purple ? 'var(--color-secondary)' : 'var(--color-text-tertiary)'}`}
  >
    {number}
  </p>
  <h3 class="font-heading text-lg md:text-xl font-semibold mb-3 text-text">{title}</h3>
  <p class="text-sm text-text-secondary font-light leading-relaxed">{description}</p>
</a>
