---
interface Props {
  title: string;
  description: string;
  date: Date;
  pillar: string;
  slug: string;
  featured?: boolean;
  headingLevel?: 'h2' | 'h3';
}

const { title, description, date, pillar, slug, featured = false, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;

const pillarLabels: Record<string, string> = {
  'merchant-mindset': 'Merchant Mindset',
  'brand-growth': 'Brand Growth',
  'ai-selling': 'AI & Selling',
  'habit-philosophy': 'Habit Philosophy',
  'founder-documentary': 'Founder Documentary',
};

const purplePillars = ['ai-selling', 'habit-philosophy'];
const isPurple = purplePillars.includes(pillar);

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readingTime = Math.max(3, Math.ceil(description.length / 40)) + ' min read';
---

<a
  href={`/thinking/${slug}/`}
  class:list={[
    "block bg-surface border border-border rounded-lg transition-all duration-200 no-underline group",
    "hover:border-border-light hover:bg-surface-hover",
    featured ? "p-10 md:p-14 col-span-full relative overflow-hidden" : "p-8 md:p-10",
  ]}
>
  {featured && (
    <div
      class="absolute -bottom-[20%] -right-[10%] w-[400px] h-[400px] pointer-events-none"
      style={`background: radial-gradient(circle, ${isPurple ? 'rgba(201,162,212,0.08)' : 'rgba(212,135,90,0.08)'} 0%, transparent 70%)`}
    />
  )}

  <div class="relative z-10">
    <p
      class="text-[0.667rem] font-medium uppercase tracking-[0.12em] mb-5"
      style={`color: ${isPurple ? 'var(--color-secondary)' : 'var(--color-accent)'}`}
    >
      {pillarLabels[pillar] || pillar}
    </p>

    <Heading
      class:list={[
        "font-heading font-semibold leading-tight mb-4 transition-colors duration-200",
        featured ? "text-2xl md:text-[2rem] max-w-[600px]" : "text-xl",
        isPurple ? "group-hover:text-secondary-light" : "group-hover:text-accent-light",
      ]}
    >
      {title}
    </Heading>

    <p class="text-text-secondary text-[0.944rem] font-light leading-relaxed mb-6">
      {description}
    </p>

    <p class="text-[0.722rem] text-text-tertiary tracking-wide">
      {formattedDate} &middot; {readingTime}
    </p>
  </div>
</a>
