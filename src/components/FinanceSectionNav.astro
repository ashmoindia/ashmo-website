---
import { financeNav } from '../data/restaurantFinance';

const currentPath = Astro.url.pathname;
---

<div class="border-y border-border bg-surface/60 backdrop-blur-sm">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12">
    <nav class="flex gap-3 md:gap-4 overflow-x-auto py-4">
      {financeNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'shrink-0 rounded-full border px-4 py-2 text-[0.72rem] font-medium uppercase tracking-[0.16em] no-underline transition-colors duration-200',
            currentPath === item.href || (item.href !== '/restaurant-finance/' && currentPath.startsWith(item.href))
              ? 'border-accent/50 bg-accent/12 text-accent-light'
              : 'border-border text-text-tertiary hover:border-border-light hover:text-text',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</div>
