---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FinanceSectionNav from '../../../components/FinanceSectionNav.astro';
---

<BaseLayout
  title="Rent-to-Revenue Calculator"
  description="Measure whether occupancy cost is commercially survivable for a UAE restaurant branch."
>
  <FinanceSectionNav />
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 pt-10 md:pt-16 pb-20 md:pb-28">
    <div class="max-w-[760px] mb-10">
      <p class="text-[0.72rem] uppercase tracking-[0.18em] text-accent mb-3">Calculator</p>
      <h1 class="font-heading text-4xl md:text-[3.6rem] tracking-[-0.04em] leading-[0.98] mb-5">Rent-to-revenue calculator</h1>
      <p class="text-[1.02rem] md:text-[1.1rem] text-text-secondary font-light leading-[1.9]">
        Use this before you call a site “premium.” The first question is whether the location can carry the rent without forcing the rest of the business into compromise.
      </p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,0.56fr)_minmax(0,0.44fr)] gap-8">
      <form id="rent-form" class="rounded-[1.5rem] border border-border bg-surface/80 px-6 py-6 md:px-8 md:py-8 space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Monthly rent + occupancy cost (AED)</span>
            <input id="monthly-rent" type="number" min="0" value="85000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Monthly net sales (AED)</span>
            <input id="monthly-sales" type="number" min="1" value="620000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
          <label class="block md:col-span-2">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Location type</span>
            <select id="location-type" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none">
              <option value="community">Community retail / neighborhood</option>
              <option value="highstreet">High street / destination</option>
              <option value="mall">Prime mall</option>
            </select>
          </label>
        </div>
      </form>
      <div class="rounded-[1.5rem] border border-border bg-[linear-gradient(145deg,rgba(21,21,20,0.95),rgba(11,11,11,0.98))] px-6 py-6 md:px-8 md:py-8">
        <p class="text-[0.72rem] uppercase tracking-[0.18em] text-accent-light mb-4">Output</p>
        <div class="space-y-5">
          <div>
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Rent to revenue</p>
            <p id="rent-ratio" class="font-heading text-[2.2rem] leading-none">13.7%</p>
          </div>
          <div class="rounded-[1.1rem] border border-border bg-surface/60 px-4 py-4">
            <p class="text-[0.68rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Commercial band</p>
            <p id="rent-band" class="text-[1.08rem] text-text">Healthy but watchful</p>
          </div>
          <div class="rounded-[1.1rem] border border-border bg-surface/60 px-4 py-4">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Decision prompt</p>
            <p id="rent-note" class="text-[0.98rem] text-text-secondary font-light leading-[1.75]">
              If occupancy cost starts demanding perfect APC, perfect labor control, and perfect delivery support, the site is too expensive for the model.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const updateRentRatio = () => {
      const rent = Number(document.getElementById('monthly-rent')?.value || 0);
      const sales = Number(document.getElementById('monthly-sales')?.value || 1);
      const type = document.getElementById('location-type')?.value || 'community';
      const ratio = sales > 0 ? (rent / sales) * 100 : 0;
      const ratioNode = document.getElementById('rent-ratio');
      const bandNode = document.getElementById('rent-band');
      const noteNode = document.getElementById('rent-note');
      ratioNode.textContent = `${ratio.toFixed(1)}%`;

      let healthy = 10;
      let warning = 14;
      if (type === 'highstreet') {
        healthy = 12;
        warning = 16;
      }
      if (type === 'mall') {
        healthy = 14;
        warning = 18;
      }

      if (ratio <= healthy) {
        bandNode.textContent = 'Healthy zone';
        noteNode.textContent = 'The occupancy cost looks more survivable. Now check whether labor and delivery dependence still behave in a weak month.';
      } else if (ratio <= warning) {
        bandNode.textContent = 'Watch closely';
        noteNode.textContent = 'The site may still work, but the branch will need real discipline in pricing, throughput, and labor. Do not underwrite this on optimism alone.';
      } else {
        bandNode.textContent = 'Commercial pressure zone';
        noteNode.textContent = 'This rent level will force too much from the branch unless the concept is genuinely built for it. Review the site before the site starts reviewing you.';
      }
    };

    document.querySelectorAll('#rent-form input, #rent-form select').forEach((input) => {
      input.addEventListener('input', updateRentRatio);
      input.addEventListener('change', updateRentRatio);
    });
    updateRentRatio();
  </script>
</BaseLayout>
