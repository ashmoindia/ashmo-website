---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FinanceSectionNav from '../../../components/FinanceSectionNav.astro';
---

<BaseLayout
  title="Labor Cost-to-Company Calculator"
  description="Translate payroll, visa, benefits, and productivity assumptions into real labor percentage for a UAE restaurant branch."
>
  <FinanceSectionNav />
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 pt-10 md:pt-16 pb-20 md:pb-28">
    <div class="max-w-[760px] mb-10">
      <p class="text-[0.72rem] uppercase tracking-[0.18em] text-accent mb-3">Calculator</p>
      <h1 class="font-heading text-4xl md:text-[3.6rem] tracking-[-0.04em] leading-[0.98] mb-5">Labor cost-to-company calculator</h1>
      <p class="text-[1.02rem] md:text-[1.1rem] text-text-secondary font-light leading-[1.9]">
        Payroll rarely tells the whole labor story in the UAE. This tool makes salary, benefits, visas, and headcount pressure visible in one place.
      </p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,0.56fr)_minmax(0,0.44fr)] gap-8">
      <form id="labor-form" class="rounded-[1.5rem] border border-border bg-surface/80 px-6 py-6 md:px-8 md:py-8 space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Monthly payroll (AED)</span>
            <input id="payroll" type="number" min="0" value="125000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Monthly benefits + allowances (AED)</span>
            <input id="benefits" type="number" min="0" value="18000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Annual visa / onboarding cost (AED)</span>
            <input id="visa-cost" type="number" min="0" value="42000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-2 block text-[0.72rem] uppercase tracking-[0.16em] text-text-tertiary">Monthly net sales (AED)</span>
            <input id="labor-sales" type="number" min="1" value="620000" class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-text focus:border-accent focus:outline-none" />
          </label>
        </div>
      </form>
      <div class="rounded-[1.5rem] border border-border bg-[linear-gradient(145deg,rgba(21,21,20,0.95),rgba(11,11,11,0.98))] px-6 py-6 md:px-8 md:py-8">
        <p class="text-[0.72rem] uppercase tracking-[0.18em] text-accent-light mb-4">Output</p>
        <div class="space-y-5">
          <div>
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">True monthly labor cost</p>
            <p id="true-labor-cost" class="font-heading text-[2.2rem] leading-none">AED 146,500</p>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-[1.1rem] border border-border bg-surface/60 px-4 py-4">
              <p class="text-[0.68rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Labor %</p>
              <p id="labor-ratio" class="text-[1.2rem] text-text">23.6%</p>
            </div>
            <div class="rounded-[1.1rem] border border-border bg-surface/60 px-4 py-4">
              <p class="text-[0.68rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Signal</p>
              <p id="labor-band" class="text-[1.08rem] text-text">Manageable</p>
            </div>
          </div>
          <div class="rounded-[1.1rem] border border-border bg-surface/60 px-4 py-4">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-text-tertiary mb-2">Decision prompt</p>
            <p id="labor-note" class="text-[0.98rem] text-text-secondary font-light leading-[1.75]">
              If labor stays too high even in healthy weeks, the branch probably has a structural scheduling or service model issue, not just a slow-sales issue.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const formatMoney = (value) => `AED ${Math.round(value).toLocaleString('en-US')}`;

    const updateLabor = () => {
      const payroll = Number(document.getElementById('payroll')?.value || 0);
      const benefits = Number(document.getElementById('benefits')?.value || 0);
      const visa = Number(document.getElementById('visa-cost')?.value || 0) / 12;
      const sales = Number(document.getElementById('labor-sales')?.value || 1);
      const total = payroll + benefits + visa;
      const ratio = sales > 0 ? (total / sales) * 100 : 0;

      document.getElementById('true-labor-cost').textContent = formatMoney(total);
      document.getElementById('labor-ratio').textContent = `${ratio.toFixed(1)}%`;

      const bandNode = document.getElementById('labor-band');
      const noteNode = document.getElementById('labor-note');
      if (ratio <= 24) {
        bandNode.textContent = 'Manageable';
        noteNode.textContent = 'The labor load looks more survivable. Keep watching productivity and sales mix, not just payroll totals.';
      } else if (ratio <= 29) {
        bandNode.textContent = 'Tight';
        noteNode.textContent = 'Labor is starting to dominate the branch economics. Review scheduling, service standards, and whether the concept is over-staffed for the throughput.';
      } else {
        bandNode.textContent = 'Overloaded';
        noteNode.textContent = 'This labor profile will be hard to defend without unusual pricing power. The branch likely needs a structural operating reset.';
      }
    };

    document.querySelectorAll('#labor-form input').forEach((input) => {
      input.addEventListener('input', updateLabor);
    });
    updateLabor();
  </script>
</BaseLayout>
