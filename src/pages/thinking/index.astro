---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('thinking', ({ data }) => data.published);
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Thinking" description="Essays by Ashraf Hassan on brand architecture, operator intelligence, and the mechanics of building businesses that last.">

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 pt-8 md:pt-16 pb-20 md:pb-24">
    <div class="mb-16">
      <h1 class="font-heading text-4xl md:text-5xl font-bold tracking-tight mb-4">Thinking</h1>
      <p class="text-lg md:text-xl text-text-secondary font-light max-w-[480px]">
        Essays by Ashraf Hassan, known as Ashmo, on brand architecture, operator decisions, and the mechanics of building businesses that compound over time.
      </p>
    </div>

    <div class="mb-16 p-8 md:p-10 bg-surface border border-border rounded-lg">
      <p class="text-[0.722rem] font-medium uppercase tracking-[0.15em] text-accent mb-5">Start Here</p>
      <div class="flex flex-col gap-4">
        <a href="/thinking/brand-positioning-hardest-thing/" class="text-text hover:text-accent transition-colors">
          Why Brand Positioning Is the Hardest Thing
        </a>
        <a href="/thinking/grocery-shop-pricing-psychology/" class="text-text hover:text-accent transition-colors">
          What a Grocery Shop at 19 Taught Me About Pricing
        </a>
        <a href="/thinking/ai-marketing-70-outlet-chain/" class="text-text hover:text-accent transition-colors">
          How AI Runs Marketing for a 100+ Outlet Chain
        </a>
      </div>
    </div>

    {sortedArticles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sortedArticles.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            pillar={article.data.pillar}
            slug={article.id}
            featured={i === 0}
            headingLevel="h2"
          />
        ))}
      </div>
    ) : (
      <p class="text-text-secondary font-light">Articles coming soon.</p>
    )}
  </section>

</BaseLayout>
