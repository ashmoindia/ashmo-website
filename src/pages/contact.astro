---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Ashraf Hassan"
  description="Get in touch with Ashraf Hassan, known as Ashmo, for strategy, collaboration, restaurant finance work, or a direct conversation."
>

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 pt-8 md:pt-16 pb-20 md:pb-28">
    <div class="max-w-[540px]">

      <h1 class="font-heading text-4xl md:text-5xl font-bold tracking-tight mb-4">Get in touch with Ashraf Hassan.</h1>
      <p class="text-lg text-text-secondary font-light leading-relaxed mb-12">
        Whether it's about brand strategy, collaboration, restaurant finance, or just a conversation — I'm Ashraf Hassan, also known as Ashmo, and I'd like to hear from you.
      </p>

      <form name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" data-netlify-recaptcha="true" class="flex flex-col gap-6">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div>
          <label for="name" class="block text-xs text-text-tertiary uppercase tracking-[0.1em] mb-2">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-text font-light focus:outline-none focus:border-accent transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-xs text-text-tertiary uppercase tracking-[0.1em] mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-text font-light focus:outline-none focus:border-accent transition-colors"
          />
        </div>

        <div>
          <label for="message" class="block text-xs text-text-tertiary uppercase tracking-[0.1em] mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-text font-light focus:outline-none focus:border-accent transition-colors resize-y"
          ></textarea>
        </div>

        <div data-netlify-recaptcha="true"></div>

        <button
          type="submit"
          class="self-start px-7 py-3 bg-accent border border-accent rounded-lg text-bg text-sm font-medium hover:bg-accent-light hover:border-accent-light transition-colors cursor-pointer"
        >
          Send Message
        </button>
      </form>

      <div class="mt-16 pt-10 border-t border-border">
        <p class="text-sm text-text-tertiary mb-3">Or find me on</p>
        <div class="flex gap-6">
          <a href="https://www.linkedin.com/in/iamashmo/" target="_blank" rel="me noopener" class="text-accent hover:text-accent-light transition-colors text-sm font-medium">LinkedIn &rarr;</a>
          <a href="https://www.instagram.com/iam_ashmo/" target="_blank" rel="me noopener" class="text-accent hover:text-accent-light transition-colors text-sm font-medium">Instagram &rarr;</a>
          <a href="https://www.youtube.com/@iamashmo" target="_blank" rel="me noopener" class="text-accent hover:text-accent-light transition-colors text-sm font-medium">YouTube &rarr;</a>
          <a href="https://www.facebook.com/iamashmo" target="_blank" rel="me noopener" class="text-accent hover:text-accent-light transition-colors text-sm font-medium">Facebook &rarr;</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
