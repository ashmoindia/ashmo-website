---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import PillarCard from '../components/PillarCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('thinking', ({ data }) => data.published);
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredArticle = sortedArticles.find(a => a.data.featured) || sortedArticles[0];
const latestArticles = sortedArticles.filter(a => a.id !== featuredArticle?.id).slice(0, 2);
---

<BaseLayout title="Home">

  <!-- Hero -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 pt-12 md:pt-20 pb-20 md:pb-28 relative">
    <!-- Warm glow -->
    <div class="absolute top-[20%] -right-[10%] w-[500px] h-[500px] pointer-events-none" style="background: radial-gradient(circle, rgba(212,135,90,0.12) 0%, transparent 70%)"></div>

    <div class="relative z-10">
      <p class="text-[0.722rem] font-medium uppercase tracking-[0.15em] text-accent mb-8 flex items-center gap-3">
        <span class="block w-8 h-px bg-accent"></span>
        Operator &middot; Brand Architect &middot; Pattern Thinker
      </p>

      <h1 class="font-heading text-4xl md:text-6xl lg:text-[3.6rem] font-bold leading-[1.08] tracking-tight mb-8 max-w-[780px]">
        Most brand problems aren't creative problems. They're <em class="italic text-accent">thinking problems.</em>
      </h1>

      <p class="text-lg md:text-xl text-text-secondary max-w-[520px] leading-relaxed font-light">
        I've spent 20 years in the operational layer of brand building — not studying it, running it. Now I write about what I learned.
      </p>

      <a href="/thinking" class="inline-flex items-center gap-2.5 mt-12 text-[0.889rem] font-medium text-text hover:text-accent transition-colors group">
        Read the thinking <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- Latest Thinking -->
  {(featuredArticle || latestArticles.length > 0) && (
    <section class="max-w-[1200px] mx-auto px-6 md:px-12 py-20 md:py-24">
      <div class="flex justify-between items-baseline mb-14 border-b border-border pb-6">
        <h2 class="text-[1.11rem] font-body font-medium uppercase tracking-[0.08em] text-text-tertiary">Latest Thinking</h2>
        <a href="/thinking" class="text-sm text-text-tertiary hover:text-accent transition-colors">View all &rarr;</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredArticle && (
          <ArticleCard
            title={featuredArticle.data.title}
            description={featuredArticle.data.description}
            date={featuredArticle.data.date}
            pillar={featuredArticle.data.pillar}
            slug={featuredArticle.id}
            featured={true}
          />
        )}

        {latestArticles.map(article => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            pillar={article.data.pillar}
            slug={article.id}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Featured Podcast -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 py-20 md:py-24">
    <div class="flex justify-between items-baseline mb-14 border-b border-border pb-6">
      <h2 class="text-[1.11rem] font-body font-medium uppercase tracking-[0.08em] text-text-tertiary">Latest Episode</h2>
      <a href="/podcast" class="text-sm text-text-tertiary hover:text-accent transition-colors">All episodes &rarr;</a>
    </div>

    <div class="bg-surface border border-border rounded-lg overflow-hidden relative">
      <div class="absolute -bottom-[20%] -right-[10%] w-[400px] h-[400px] pointer-events-none" style="background: radial-gradient(circle, rgba(212,135,90,0.08) 0%, transparent 70%)"></div>
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="aspect-video">
          <iframe
            src="https://www.youtube.com/embed/E0W1FqtuKw0"
            title="CAFE PROFIT: This Is What Successful Coffee Shop Owners Do Differently"
            class="w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <div class="p-8 md:p-10 flex flex-col justify-center relative z-10">
          <p class="text-[0.667rem] font-medium uppercase tracking-[0.12em] text-accent mb-4">The eCom Show &middot; #86</p>
          <h3 class="font-heading text-xl md:text-2xl font-semibold leading-tight mb-4">CAFE PROFIT: This Is What Successful Coffee Shop Owners Do Differently</h3>
          <p class="text-text-secondary font-light leading-relaxed text-[0.944rem] mb-6">What separates thriving cafe owners from those who struggle? The strategies, brand thinking, and operational discipline behind building a 70+ outlet cafe chain.</p>
          <a href="/podcast" class="inline-flex items-center gap-2 text-[0.889rem] font-medium text-accent hover:text-accent-light transition-colors group">
            Watch full episode <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Quote -->
  <section class="py-24 md:py-32 text-center relative">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] pointer-events-none" style="background: radial-gradient(circle, rgba(201,162,212,0.12) 0%, transparent 60%)"></div>
    <blockquote class="font-heading text-2xl md:text-3xl font-semibold leading-[1.3] text-text max-w-[600px] mx-auto px-6 relative z-10">
      "Brand consistency is an operational discipline. Not a creative one."
    </blockquote>
    <p class="mt-6 text-sm text-text-tertiary tracking-wide relative z-10">— Ashmo</p>
  </section>

  <!-- About Teaser -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 py-20 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
      <div class="aspect-[4/5] bg-surface rounded-lg border border-border relative overflow-hidden">
        <img src="/images/ashmo-portrait.webp" alt="Ashmo — founder, brand builder" width="516" height="696" loading="eager" fetchpriority="high" class="w-full h-full object-cover object-top" />
        <div class="absolute bottom-0 left-0 right-0 h-1/2 pointer-events-none" style="background: linear-gradient(to top, rgba(212,135,90,0.12), transparent)"></div>
      </div>
      <div>
        <h2 class="font-heading text-3xl md:text-[2.4rem] font-semibold leading-[1.15] mb-6">
          Twenty years of execution. One brand scaled from a single outlet to 70+.
        </h2>
        <p class="text-[1.05rem] text-text-secondary font-light leading-[1.75] mb-6">
          I started with a grocery shop in Deira at 19. Moved through design, IT, and creative work. Then spent two decades in the operational layer of brand building — making the calls, designing the systems, living with the decisions.
        </p>
        <p class="text-[1.05rem] text-text-secondary font-light leading-[1.75] mb-8">
          What I write about is the interior architecture of that: how positioning decisions compound, how brand consistency is actually an operational problem, and why clear thinking is the real competitive advantage.
        </p>
        <a href="/story" class="inline-flex items-center gap-2 text-[0.889rem] font-medium text-accent hover:text-accent-light transition-colors group">
          The background <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Pillars -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 py-20 md:py-24">
    <div class="flex justify-between items-baseline mb-14 border-b border-border pb-6">
      <h2 class="text-[1.11rem] font-body font-medium uppercase tracking-[0.08em] text-text-tertiary">What I Write About</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <PillarCard number="01" title="Operator Intelligence" description="How real businesses make decisions. Pricing, footfall, selling, margins — the intelligence of the ground floor, not the boardroom." />
      <PillarCard number="02" title="Brand Architecture" description="The structural decisions that make brands consistent, scalable, and hard to replace. Built from two decades at one brand." />
      <PillarCard number="03" title="The New Operating Layer" description="How AI is reshaping the mechanics of marketing, selling, and brand management — from someone running it at scale." purple={true} />
      <PillarCard number="04" title="Execution Philosophy" description="The mental operating system behind long games. Patience, compounding decisions, and the discipline of staying clear under pressure." purple={true} />
      <PillarCard number="05" title="Field Notes" description="Short dispatches from inside the work. Observations, decisions, and the small things that turn out to matter." />
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 py-24 border-t border-border">
    <div class="max-w-[580px]">
      <p class="font-heading text-2xl md:text-3xl font-normal leading-[1.3] text-text mb-6">
        If you're building something and the thinking feels muddy —
      </p>
      <p class="text-[1.05rem] text-text-secondary font-light leading-[1.75] mb-10">
        The positioning isn't landing. The brand isn't compounding. The decisions don't feel like a system yet. That's what this platform is built around.
      </p>
      <div class="flex flex-col sm:flex-row gap-6">
        <a href="/thinking" class="inline-flex items-center gap-2 text-[0.889rem] font-medium text-accent hover:text-accent-light transition-colors group">
          Start with the thinking <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href="/principles" class="inline-flex items-center gap-2 text-[0.889rem] font-medium text-text-tertiary hover:text-text-secondary transition-colors group">
          Read the principles <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 text-[0.889rem] font-medium text-text-tertiary hover:text-text-secondary transition-colors group">
          Reach out directly <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
